{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@obsync/crypto": ["./src/vendor/obsync-crypto/index.ts"],
      "@obsync/proto": ["./src/vendor/obsync-proto/index.ts"]
    },
    "types": ["node"]
  },
  "include": ["src/**/*", "main.ts", "types/**/*"]
}
